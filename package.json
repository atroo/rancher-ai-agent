{
  "name": "ai-assistant-app",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "build-pkg": "bash node_modules/@rancher/shell/scripts/build-pkg.sh",
    "dev": "concurrently \"nodemon --watch pkg/ai-assistant --ext js,vue,json,css -x 'yarn build-pkg -d ai-assistant'\" \"yarn serve-pkgs\"",
    "serve-pkgs": "node node_modules/@rancher/shell/scripts/serve-pkgs",
    "publish-pkgs": "bash node_modules/@rancher/shell/scripts/extension/publish",
    "parse-tag-name": "bash node_modules/@rancher/shell/scripts/extension/parse-tag-name"
  },
  "dependencies": {
    "@rancher/shell": "^3.0.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-plugin-typescript": "~5.0.8",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "~5.3.3"
  },
  "overrides": {
    "webpack": "5.105.4"
  },
  "engines": {
    "node": ">=20 <25"
  }
}
